import torch
import torch.nn as nn
import torch.nn.functional as F
from pointnet2 import pointnet2_utils
from pointnet2.pointnet2_modules import PointnetFPModule


def make_gn(num_channels, num_groups=16):
    num_groups = min(num_groups, num_channels)
    while num_groups > 1 and (num_channels % num_groups) != 0:
        num_groups -= 1
    return nn.GroupNorm(num_groups, num_channels)

class PointSpatialAttention(nn.Module):
    def __init__(self, channels):
        super().__init__()
        mid_channels = max(1, channels // 4)
        self.conv1 = nn.Conv2d(channels, mid_channels, 1)
        self.conv2 = nn.Conv2d(mid_channels, 1, 1)
        self.sigmoid = nn.Sigmoid()

    def forward(self, x):
        attn = self.conv1(x)
        attn = F.relu(attn, inplace=True)
        attn = self.conv2(attn)
        attn = self.sigmoid(attn)
        return x * attn

class ResidualMLPBlock(nn.Module):
    def __init__(self, channels):
        super().__init__()
        self.linear1 = nn.Conv2d(channels, channels, 1)
        self.norm1 = make_gn(channels)
        self.act1 = nn.ReLU(inplace=True)

        self.attn = PointSpatialAttention(channels)

        self.linear2 = nn.Conv2d(channels, channels, 1)
        self.norm2 = make_gn(channels)

    def forward(self, x):
        identity = x
        out = self.linear1(x)
        out = self.norm1(out)
        out = self.act1(out)
        out = self.attn(out)
        out = self.linear2(out)
        out = self.norm2(out)
        return F.relu(out + identity, inplace=True)

class LocalSpatialEncoding(nn.Module):
    def __init__(self):
        super().__init__()

    def forward(self, grouped_xyz, grouped_features):
        relative_xyz = grouped_xyz - grouped_xyz[:, :, :, 0:1]   
        distance = torch.norm(relative_xyz, dim=1, keepdim=True) 

        if grouped_features is None:
            fused = torch.cat([relative_xyz, distance], dim=1)  
        else:
            fused = torch.cat([grouped_features, relative_xyz, distance], dim=1)
        return fused

class PointNeXtBlock(nn.Module):
    def __init__(self,
                 in_channels,
                 out_channels,
                 npoint,
                 radius,
                 nsample,
                 depth=3,
                 hidden_dim=None):
        super().__init__()
        self.npoint = npoint
        self.radius = radius
        self.nsample = nsample
        self.depth = depth

        if hidden_dim is None:
            hidden_dim = out_channels
        self.group = pointnet2_utils.QueryAndGroup(
            radius, nsample, use_xyz=True, ret_grouped_xyz=True
        )

        self.lse = LocalSpatialEncoding()
        conv_in_channels = in_channels + 7
        self.input_proj = nn.Sequential(
            nn.Conv2d(conv_in_channels, hidden_dim, 1),
            make_gn(hidden_dim),
            nn.ReLU(inplace=True)
        )

        self.mlp_blocks = nn.Sequential(*[
            ResidualMLPBlock(hidden_dim) for _ in range(depth)
        ])

        self.out_proj = nn.Sequential(
            nn.Conv2d(hidden_dim, out_channels, 1),
            make_gn(out_channels),
            nn.ReLU(inplace=True)
        )

    def forward(self, xyz, features):
        B, N, _ = xyz.shape
        fps_idx = pointnet2_utils.furthest_point_sample(xyz, self.npoint)        
        new_xyz = pointnet2_utils.gather_operation(
            xyz.transpose(1, 2).contiguous(), fps_idx
        ).transpose(1, 2).contiguous()                                       

        grouped_features, grouped_xyz = self.group(xyz, new_xyz, features)
        new_xyz_exp = new_xyz.transpose(1, 2).unsqueeze(-1).expand(-1, -1, -1, self.nsample)
        grouped_xyz_centered = grouped_xyz - new_xyz_exp
        fused = self.lse(grouped_xyz_centered, grouped_features)
        x = self.input_proj(fused)
        x = self.mlp_blocks(x)
        x = self.out_proj(x)
        new_features = torch.max(x, dim=-1)[0]
        return new_xyz, new_features, fps_idx
class PointNeXtBackbone(nn.Module):
    def __init__(self, input_feature_dim=0, radius_scale=1.0):
        super().__init__()
        r1 = 0.15 * radius_scale
        r2 = 0.30 * radius_scale
        r3 = 0.10 * radius_scale
        r4 = 0.40 * radius_scale

        self.sa1 = PointNeXtBlock(
            in_channels=input_feature_dim,
            out_channels=128,
            npoint=1024,
            radius=r1,
            nsample=48,
            depth=3
        )
        self.sa2 = PointNeXtBlock(
            in_channels=128,
            out_channels=256,
            npoint=512,
            radius=r2,
            nsample=32,
            depth=3
        )
        self.sa3 = PointNeXtBlock(
            in_channels=256,
            out_channels=256,
            npoint=256,
            radius=r3,
            nsample=32,
            depth=3
        )
        self.sa4 = PointNeXtBlock(
            in_channels=256,
            out_channels=256,
            npoint=128,
            radius=r4,
            nsample=32,
            depth=3
        )

        self.fp1 = PointnetFPModule(mlp=[256 + 256, 256, 256])
        self.fp2 = PointnetFPModule(mlp=[256 + 256, 256, 256]) 
        self.out_align = nn.Sequential(
            nn.Conv1d(256, 256, 1),
            make_gn(256),
            nn.ReLU(inplace=True)
        )

    def _break_up_pc(self, pc):
        xyz = pc[..., 0:3].contiguous()
        features = (
            pc[..., 3:].transpose(1, 2).contiguous()
            if pc.size(-1) > 3 else None
        )
        return xyz, features


    def forward(self, pointcloud, end_points=None):
        if end_points is None:
            end_points = {}

        xyz, features = self._break_up_pc(pointcloud)
        xyz1, features1, fps1 = self.sa1(xyz, features)
        end_points['sa1_xyz'] = xyz1
        end_points['sa1_features'] = features1
        end_points['sa1_inds'] = fps1

        xyz2, features2, fps2 = self.sa2(xyz1, features1)
        end_points['sa2_xyz'] = xyz2
        end_points['sa2_features'] = features2
        end_points['sa2_inds'] = fps2

        xyz3, features3, fps3 = self.sa3(xyz2, features2)
        end_points['sa3_xyz'] = xyz3
        end_points['sa3_features'] = features3

        xyz4, features4, fps4 = self.sa4(xyz3, features3)
        end_points['sa4_xyz'] = xyz4
        end_points['sa4_features'] = features4

        fp1_feat = self.fp1(xyz3, xyz4, features3, features4)  
        fp2_feat = self.fp2(xyz2, xyz3, features2, fp1_feat)  

        fp2_feat = self.out_align(fp2_feat)                 

        end_points['fp2_xyz'] = xyz2                    
        end_points['fp2_features'] = fp2_feat               
        end_points['fp2_inds'] = end_points['sa1_inds'][:, :xyz2.shape[1]]

        return end_points

